# MongoDB Atlas connection string
# Format: mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority&appName=<AppName>
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=AI-TUTOR

# MongoDB database name for auth/users/sessions/chat history
MONGODB_DB=ai_tutor_auth

# Optional existing app settings
JWT_SECRET=replace-with-strong-secret

# Gemini settings
GEMINI_API_KEY=replace-with-gemini-api-key
GEMINI_TEXT_MODEL=gemini-1.5-flash
GEMINI_VISION_MODEL=gemini-1.5-flash

# Embedding model
EMBED_MODEL=all-MiniLM-L6-v2

# Google auth
GOOGLE_CLIENT_ID=replace-with-google-client-id

# Frontend public API URL
# Local: http://localhost:8000
# Railway: https://<your-backend-service>.up.railway.app
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
